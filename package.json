{
  "name": "finanzapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "run-p typecheck lint format:check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed:dev": "tsx scripts/seed-db.ts",
    "reset:test": "tsx scripts/reset-test-user-data.ts",
    "setup:hooks": "git config core.hooksPath .githooks",
    "audit": "pnpm audit --audit-level=critical",
    "audit:high": "pnpm audit --audit-level=high",
    "audit:all": "pnpm audit",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,scss,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
